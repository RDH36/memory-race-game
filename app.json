{
  "expo": {
    "name": "Flipia",
    "slug": "flipia",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "flipia",
    "splash": {
      "image": "./assets/adaptive-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#534AB7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rdh36.flipia"
    },
    "android": {
      "adaptiveIcon": "./assets/adaptive-icon.png",
      "package": "com.rdh36.flipia"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"]
  }
}
